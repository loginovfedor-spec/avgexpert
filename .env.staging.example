# Staging deployment template (S9-2)
# Copy to staging host .env and fill secrets.

NODE_ENV=production
AVGEXPERT_DEPLOY_ENV=staging

# RAG v2 on by default when AVGEXPERT_DEPLOY_ENV=staging (override explicitly if needed)
# RAG_V2_ENABLED=true

KNOWLEDGE_GATEWAY_ENABLED=true

# SQLite FTS degraded fallback (S10-2)
FTS_FALLBACK_ENABLED=true

AVGEXPERT_PORT=8200
AVGEXPERT_SECRET=replace-with-staging-secret-at-least-32-chars
AVGEXPERT_ADMIN_PASSWORD=change-me-immediately

VECTOR_EMBEDDING_CONFIG=bge_m3
EMBEDDING_PROVIDER=self-hosted
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024
EMBEDDING_NAMESPACE=bge-m3-v1
EMBEDDING_MOCK=false

VECTOR_STORE=pgvector
# DATABASE_URL=postgresql://...
