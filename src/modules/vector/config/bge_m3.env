# Self-hosted embedder bge-m3 (RAG v2 §11.1)
# Источник параметров для VectorKB; переопределяется корневым .env при необходимости.

EMBEDDING_PROVIDER=self-hosted
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024
# Финальная фиксация namespace — после gate S0-6 (§11.3)
EMBEDDING_NAMESPACE=bge-m3-v1

# Text Embeddings Inference (TEI) / HuggingFace embed API в VPC рядом с PG (83.166.253.250)
EMBEDDING_API_URL=http://83.166.253.250:8080/embed
EMBEDDING_API_FORMAT=tei
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 
