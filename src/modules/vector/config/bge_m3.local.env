# Self-hosted embedder bge-m3 — локальная среда (docker compose TEI)
# Запуск: npm run local:up

EMBEDDING_PROVIDER=self-hosted
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024
EMBEDDING_NAMESPACE=bge-m3-v1

EMBEDDING_API_URL=http://127.0.0.1:8090/embed
EMBEDDING_API_FORMAT=tei
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages: 
