{
  "name": "avgexpert-gateway",
  "version": "1.0.0",
  "description": "AvgExpert — API Gateway with user auth",
  "main": "server.ts",
  "scripts": {
    "prestart": "node scripts/ensure-better-sqlite3.js && node scripts/ensure-webui-dist.js",
    "start": "tsx server.ts",
    "rebuild:native": "node scripts/ensure-better-sqlite3.js",
    "stop": "node scripts/stop.js",
    "restart": "npm run stop && npm run start",
    "worker": "tsx src/modules/temporal/worker.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run typecheck && npm run test:pr && npm run test:security && npm run test:policy && npm run test:knowledge",
    "test": "tsx --test --test-concurrency=1 tests/*.test.js",
    "test:unit": "tsx --test tests/provider_events.test.js tests/errors.test.js tests/deterministic_provider.test.js",
    "test:contract": "tsx --test tests/contract_canonical_event.test.js tests/fast_path_guardrail.test.js",
    "test:security": "tsx --test tests/security.test.js tests/security_assertions.test.js tests/baseline_security.test.js",
    "test:security:smoke": "tsx --test tests/security_assertions.test.js",
    "test:integration": "tsx --test --test-concurrency=1 tests/api.test.js tests/health.test.js",
    "test:integration:smoke": "tsx --test tests/health.test.js",
    "test:latency": "tsx --test tests/latency_baseline.test.js",
    "eval:rag": "node tests/evals/rag.eval.js",
    "eval:consultant-recall": "tsx tests/evals/rag_consultant_recall.eval.js",
    "eval:tier-recall": "tsx tests/evals/rag_tier_recall.eval.js",
    "eval:expert-rerank": "tsx tests/evals/rag_expert_rerank.eval.js",
    "eval:recall": "node tests/evals/rag_recall.eval.js",
    "eval:recall-at-k": "node scratch/recall_at_k_eval.js",
    "bench:rag-tier": "node scratch/compare_rag_models.js --mode=inject-only --json=scratch/rag_tier_baseline.json --quiet",
    "eval:full": "npm run eval:rag && npm run eval:recall",
    "test:policy": "tsx --test tests/policy/*.test.js",
    "test:knowledge": "tsx --test tests/knowledge/*.test.js tests/knowledge/*.test.ts",
    "test:vector": "tsx --test tests/vector/*.test.ts",
    "test:rag": "tsx --test tests/rag/*.test.ts",
    "test:s4": "tsx --test tests/rag/degraded.retriever.test.ts tests/migrations/v027_llm_cache_consultant.test.js tests/yandex_inject_only.test.js tests/providers/llm_response_cache.test.js",
    "test:s5": "tsx --test tests/kb/upload.validation.test.ts tests/kb/user.documents.test.ts tests/rag/document-context.resolver.test.ts tests/rag/tenant-isolation.test.ts",
    "test:s6": "tsx --test tests/kb/session.attachments.test.ts tests/kb/upload.validation.test.ts",
    "test:s7": "tsx --test tests/rag/metadata-scoring.test.ts tests/rag/tiered.retriever.s7.test.ts tests/migrations/v028_tier_provider_categories.test.js",
    "test:s7b": "tsx --test tests/vector/selfhosted.reranker.test.ts tests/vector/reranker.service.test.ts tests/rag/tiered.retriever.s7b.test.ts tests/rag/rerank.latency.test.ts",
    "test:s8": "tsx --test tests/rag/domain-tags-filter.test.ts tests/rag/tiered.retriever.s8.test.ts tests/semantic/entity-extraction.test.ts tests/semantic/semantic-graph.service.test.ts tests/semantic/semantic-graph.connection.test.ts tests/vector/semantic-graph.migration.test.ts",
    "test:s9": "tsx --test tests/yandex_file_search_no_pg.test.js tests/rag_v2_config.test.js tests/rag/retrieval.load.test.ts tests/kb/upload.rate-limit.test.ts tests/rag/tenant-isolation.test.ts",
    "test:s10": "tsx --test tests/rag_v2_config.test.js tests/rag/fts-fallback-flag.test.ts tests/rag/grok-no-collection.test.ts tests/rag/rag-metrics.test.ts tests/rag/degraded.retriever.test.ts tests/rag/rag.orchestrator.test.ts",
    "load:rag-retrieval": "tsx scripts/rag_retrieval_load.ts",
    "spike:semantic-graph": "tsx scripts/semantic_graph_spike.ts",
    "kb:pg:migrate": "tsx scripts/kb_pg_migrate.ts",
    "kb:pg:smoke": "tsx scripts/pgvector_smoke.ts",
    "app:pg:smoke": "tsx scripts/app_pg_smoke.ts",
    "test:d2": "tsx --test tests/pg/app.migrations.test.ts",
    "test:d3": "tsx --test tests/pg/app.sessions.test.ts",
    "kb:ingest": "tsx scripts/kb_ingest.ts",
    "kb:reindex-books": "tsx scripts/kb_reindex_books.ts",
    "embedding:smoke": "tsx scripts/embedding_smoke.ts",
    "local:up": "tsx scripts/local_stack.ts up",
    "local:down": "tsx scripts/local_stack.ts down",
    "local:status": "tsx scripts/local_stack.ts status",
    "local:wait": "tsx scripts/local_stack.ts wait",
    "local:smoke": "tsx scripts/local_stack.ts smoke",
    "prod:up": "docker compose --env-file deploy/prod/.env -f deploy/prod/compose.yml up -d --build",
    "prod:down": "docker compose --env-file deploy/prod/.env -f deploy/prod/compose.yml down",
    "prod:ps": "docker compose --env-file deploy/prod/.env -f deploy/prod/compose.yml ps",
    "prod:logs": "docker compose --env-file deploy/prod/.env -f deploy/prod/compose.yml logs -f",
    "prod:post-deploy": "bash deploy/prod/scripts/post-deploy.sh",
    "prod:migrate-rag": "bash deploy/prod/scripts/migrate-rag-db.sh",
    "prod:migrate-rag:dry": "bash deploy/prod/scripts/migrate-rag-db.sh --dry-run",
    "prod:pg-backup": "bash deploy/prod/scripts/pg-backup.sh",
    "prod:check-gpu": "bash deploy/prod/scripts/check-gpu.sh",
    "prod:prepare-server": "bash deploy/prod/scripts/prepare-server.sh",
    "prod:ssh-prepare": "bash deploy/prod/scripts/ssh-deploy.sh prepare",
    "prod:ssh-install": "bash deploy/prod/scripts/ssh-deploy.sh install",
    "prod:ssh-update": "bash deploy/prod/scripts/ssh-deploy.sh update",
    "prod:ssh-status": "bash deploy/prod/scripts/ssh-deploy.sh status",
    "test:pr": "tsx --test tests/provider_events.test.js tests/errors.test.js tests/deterministic_provider.test.js tests/contract_canonical_event.test.js tests/fast_path_guardrail.test.js tests/security_assertions.test.js tests/health.test.js",
    "test:nightly": "tsx --test --test-concurrency=1 tests/*.test.js tests/policy/*.test.js tests/knowledge/*.test.js",
    "test:release": "tsx --test --test-concurrency=1 tests/*.test.js tests/policy/*.test.js tests/knowledge/*.test.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^6.35.0",
    "pg": "^8.21.0",
    "tsx": "^4.22.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dompurify": "^3.4.8",
    "eslint": "^10.4.1",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "pdfjs-dist": "^6.0.227",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wtfnode": "^0.10.1"
  }
}
