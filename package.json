{
  "name": "avgexpert-gateway",
  "version": "1.0.0",
  "description": "AvgExpert — API Gateway with user auth",
  "main": "server.ts",
  "scripts": {
    "postinstall": "npm install --prefix src/modules/providers/adapters/yandex_file_search_pg --omit=dev",
    "prestart": "node scripts/ensure-better-sqlite3.js",
    "start": "tsx server.ts",
    "rebuild:native": "node scripts/ensure-better-sqlite3.js",
    "stop": "node scripts/stop.js",
    "restart": "npm run stop && npm run start",
    "worker": "tsx src/modules/temporal/worker.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run typecheck && npm run test:pr && npm run test:security && npm run test:policy && npm run test:knowledge",
    "test": "tsx --test --test-concurrency=1 tests/*.test.js",
    "test:unit": "tsx --test tests/provider_events.test.js tests/errors.test.js tests/deterministic_provider.test.js",
    "test:contract": "tsx --test tests/contract_canonical_event.test.js tests/fast_path_guardrail.test.js",
    "test:security": "tsx --test tests/security.test.js tests/security_assertions.test.js tests/baseline_security.test.js",
    "test:security:smoke": "tsx --test tests/security_assertions.test.js",
    "test:integration": "tsx --test --test-concurrency=1 tests/api.test.js tests/health.test.js",
    "test:integration:smoke": "tsx --test tests/health.test.js",
    "test:latency": "tsx --test tests/latency_baseline.test.js",
    "eval:rag": "node tests/evals/rag.eval.js",
    "eval:recall": "node tests/evals/rag_recall.eval.js",
    "eval:recall-at-k": "node scratch/recall_at_k_eval.js",
    "bench:rag-tier": "node scratch/compare_rag_models.js --mode=inject-only --json=scratch/rag_tier_baseline.json --quiet",
    "eval:full": "npm run eval:rag && npm run eval:recall",
    "test:policy": "tsx --test tests/policy/*.test.js",
    "test:knowledge": "tsx --test tests/knowledge/*.test.js tests/knowledge/*.test.ts",
    "test:vector": "tsx --test tests/vector/*.test.ts",
    "test:rag": "tsx --test tests/rag/*.test.ts",
    "kb:pg:migrate": "tsx scripts/kb_pg_migrate.ts",
    "kb:pg:smoke": "tsx scripts/pgvector_smoke.ts",
    "kb:ingest": "tsx scripts/kb_ingest.ts",
    "kb:reindex-books": "tsx scripts/kb_reindex_books.ts",
    "embedding:smoke": "tsx scripts/embedding_smoke.ts",
    "local:up": "tsx scripts/local_stack.ts up",
    "local:down": "tsx scripts/local_stack.ts down",
    "local:status": "tsx scripts/local_stack.ts status",
    "local:wait": "tsx scripts/local_stack.ts wait",
    "local:smoke": "tsx scripts/local_stack.ts smoke",
    "test:pr": "tsx --test tests/provider_events.test.js tests/errors.test.js tests/deterministic_provider.test.js tests/contract_canonical_event.test.js tests/fast_path_guardrail.test.js tests/security_assertions.test.js tests/health.test.js",
    "test:nightly": "tsx --test --test-concurrency=1 tests/*.test.js tests/policy/*.test.js tests/knowledge/*.test.js",
    "test:release": "tsx --test --test-concurrency=1 tests/*.test.js tests/policy/*.test.js tests/knowledge/*.test.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^6.35.0",
    "pg": "^8.21.0",
    "tsx": "^4.22.4",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dompurify": "^3.4.8",
    "eslint": "^10.4.1",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "pdfjs-dist": "^6.0.227",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wtfnode": "^0.10.1"
  }
}
