# Ноутбук → удалённые сервисы в Docker на pilot-сервере
# cp deploy/dev/env.laptop-remote.example .env
# Перед npm start: SSH-туннели (см. deploy/dev/DEV_REMOTE.md)

NODE_ENV=development
AVGEXPERT_DEPLOY_ENV=development

AVGEXPERT_PORT=8200
AVGEXPERT_SECRET=replace-with-at-least-32-random-characters
AVGEXPERT_ADMIN_PASSWORD=change-me-immediately
AVGEXPERT_ALLOWED_ORIGINS=http://127.0.0.1:8200,http://localhost:8200

# PostgreSQL 18 на pilot (через туннель localhost:5433 → server:5432)
DATABASE_URL=postgresql://avg:PASSWORD@127.0.0.1:5433/avgexpert

VECTOR_STORE=pgvector
VECTOR_EMBEDDING_CONFIG=bge_m3.local
EMBEDDING_MOCK=false
EMBEDDING_API_URL=http://127.0.0.1:8090/embed

VECTOR_RERANKER_CONFIG=bge_reranker_v2_m3.local
RERANK_ENABLED=true
RERANK_MOCK=false
RERANK_API_URL=http://127.0.0.1:8091/rerank

LLAMACPP_URL=http://127.0.0.1:8201/v1
LLAMACPP_DEFAULT_MODEL=qwen2.5-7b-instruct

RAG_V2_ENABLED=true
KNOWLEDGE_GATEWAY_ENABLED=true

# FTS fallback: PG tsvector (russian) на kb_chunks
FTS_FALLBACK_ENABLED=true
FTS_FALLBACK_BACKEND=pg_tsvector
