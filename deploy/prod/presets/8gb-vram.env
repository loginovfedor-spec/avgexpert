# Preset: Tesla L4 vGPU-8-16-L4-8Q (8192 MB VRAM, 16 GB RAM)
# Скопируйте нужные строки в deploy/prod/.env
#
# Баланс по умолчанию: TEI на GPU + Llama 7B гибрид (24 слоя на GPU)

TEI_CUDA_IMAGE=ghcr.io/huggingface/text-embeddings-inference:89-1.7
TEI_MAX_BATCH_TOKENS=2048

LLAMA_CTX_SIZE=4096
LLAMA_THREADS=4
LLAMA_BATCH=256
LLAMA_N_GPU_LAYERS=24

# --- Альтернатива A: максимум качества локального чата (RAG embed медленнее) ---
# docker compose -f deploy/prod/compose.yml -f deploy/prod/compose.tei-cpu.override.yml up -d
# LLAMA_N_GPU_LAYERS=99
# LLAMA_CTX_SIZE=8192

# --- Альтернатива B: меньшая модель, всё на GPU без OOM ---
# LLAMA_MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-3B-Instruct-GGUF/resolve/main/Qwen2.5-3B-Instruct-Q4_K_M.gguf
# LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf
# LLAMA_N_GPU_LAYERS=99
# LLAMA_CTX_SIZE=8192
