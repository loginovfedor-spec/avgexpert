# Preset: L4 8 GB — TEI на CPU, Llama 7B на полный GPU
# Требует nvidia-smi + NVIDIA Container Toolkit
# Скопируйте в deploy/prod/.env:
#   COMPOSE_STACK=gpu-l4-8gb

COMPOSE_STACK=gpu-l4-8gb

LLAMA_CTX_SIZE=8192
LLAMA_THREADS=4
LLAMA_BATCH=256
LLAMA_N_GPU_LAYERS=99

# Альтернатива: меньшая модель
# LLAMA_MODEL_URL=https://huggingface.co/bartowski/Qwen2.5-3B-Instruct-GGUF/resolve/main/Qwen2.5-3B-Instruct-Q4_K_M.gguf
# LLAMA_MODEL_FILE=Qwen2.5-3B-Instruct-Q4_K_M.gguf
