# Preset: Tesla L4 vGPU-8-16-L4-8Q — TEI и Llama на GPU (гибрид)
# Требует nvidia-smi + NVIDIA Container Toolkit
# Скопируйте в deploy/prod/.env:
#   COMPOSE_STACK=gpu-l4

COMPOSE_STACK=gpu-l4

TEI_CUDA_IMAGE=ghcr.io/huggingface/text-embeddings-inference:89-1.7
TEI_MAX_BATCH_TOKENS=2048

LLAMA_CTX_SIZE=4096
LLAMA_THREADS=4
LLAMA_BATCH=256
LLAMA_N_GPU_LAYERS=24
