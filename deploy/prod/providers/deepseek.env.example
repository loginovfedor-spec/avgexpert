PROVIDER_NAME="DeepSeek"
ADAPTER_TYPE=deepseek
DEEPSEEK_URL=http://envoy:8080/deepseek/v1
DEEPSEEK_API_KEY=sk-replace-me
DEFAULT_MODEL=deepseek-chat
MODELS=deepseek-chat,deepseek-reasoner

# Cost (SPEC-COST-TRACKING §3/§10): USD за 1M токенов (deepseek-chat / V4 tier)
COST_USD_PER_1M_INPUT=0.14
COST_USD_PER_1M_CACHED_INPUT=0.0028
COST_USD_PER_1M_OUTPUT=0.28
COST_MODE=standard
COST_CURRENCY=USD
COST_EXCHANGE_RATE=1.0
