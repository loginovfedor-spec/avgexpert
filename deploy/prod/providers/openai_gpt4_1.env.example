PROVIDER_NAME="OpenAI GPT-4.1"
ADAPTER_TYPE=openai_gpt4_1
OPENAI_URL=http://envoy:8080/openai/v1
OPENAI_API_KEY=sk-replace-me
DEFAULT_MODEL=gpt-4.1
MODELS=gpt-4.1,gpt-4.1-mini
TEMPERATURE=0.7
TOP_P=0.9
MAX_OUTPUT_TOKENS=32768
WEB_SEARCH_ENABLED=false
IMAGE_UPLOAD_ENABLED=false

# Cost (SPEC-COST-TRACKING §2/§10): USD за 1M токенов
COST_USD_PER_1M_INPUT=2.00
COST_USD_PER_1M_CACHED_INPUT=0.50
COST_USD_PER_1M_OUTPUT=8.00
COST_MODE=standard
COST_CURRENCY=USD
COST_EXCHANGE_RATE=1.0
