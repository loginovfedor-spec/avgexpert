PROVIDER_NAME="Консультант (Local GPU)"
ADAPTER_TYPE=llamacpp

LLAMACPP_URL=http://llama-cpp:8080/v1
LLAMACPP_API_KEY=
LLAMACPP_DEFAULT_MODEL=qwen2.5-7b-instruct
MODELS=qwen2.5-7b-instruct

# N_CTX <= LLAMA_CTX_SIZE in deploy/prod/.env (compose llama-cpp service)
N_CTX=4096
MAX_OUTPUT_GENERATION_TOKENS=4096

TEMPERATURE=0.5
TOP_P=0.9
TOP_K=40
MIN_P=0.05
REPEAT_PENALTY=1.1

PROVIDER_TIMEOUT_MS=300000

# Docker llama-cpp: deploy/prod/compose.yml → LLAMA_MODEL_URL, LLAMA_MODEL_FILE,
# LLAMA_CTX_SIZE, LLAMA_THREADS, LLAMA_BATCH, LLAMA_N_GPU_LAYERS (from deploy/prod/.env)

# Cost (compute-mode, SPEC §8) — задать при деплое по фактическому железу
COST_MODE=compute
COST_USD_PER_HOUR=0.50
COST_MIN_BILLABLE_SECONDS=1
COST_CURRENCY=USD
