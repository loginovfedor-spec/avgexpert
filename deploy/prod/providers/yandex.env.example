PROVIDER_NAME="Yandex Cloud"
ADAPTER_TYPE=yandex
YANDEX_CLOUD_FOLDER=b1gxxxxxxxxxx
YANDEX_CLOUD_API_KEY=AQVNxxxxxxxx
YANDEX_CLOUD_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_CLOUD_MODEL=aliceai-llm-flash/latest
YANDEX_CLOUD_API_MODE=chat_completions
YANDEX_CLOUD_RESPONSE_FORMAT=text
YANDEX_CLOUD_TEMPERATURE=0.5
YANDEX_CLOUD_MAX_OUTPUT_TOKENS=4096
YANDEX_DEFAULT_MODEL=aliceai-llm-flash/latest
MODELS=aliceai-llm-flash/latest,aliceai-llm/latest

# Cost (SPEC §7/§10): sync pricing, RUB за 1M токенов
COST_USD_PER_1M_INPUT=4.10
COST_USD_PER_1M_OUTPUT=4.10
COST_MODE=standard
COST_CURRENCY=RUB
COST_EXCHANGE_RATE=1.0
