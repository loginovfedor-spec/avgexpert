PROVIDER_NAME="Qwen (DashScope)"
ADAPTER_TYPE=qwen
QWEN_URL=http://envoy:8080/qwen/compatible-mode/v1
QWEN_API_KEY=sk-replace-me
QWEN_DEFAULT_MODEL=qwen-plus
MODELS=qwen-plus,qwen-max,qwen-turbo

# Cost (SPEC-COST-TRACKING §6/§10): USD за 1M токенов (qwen-plus / qwen3.7-plus tier)
COST_USD_PER_1M_INPUT=0.40
COST_USD_PER_1M_CACHED_INPUT=0.04
COST_USD_PER_1M_OUTPUT=1.60
COST_MODE=standard
COST_CURRENCY=USD
COST_EXCHANGE_RATE=1.0
