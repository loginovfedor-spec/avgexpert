# Copy to deploy/prod/.env and fill secrets:
#   cp deploy/prod/env.example deploy/prod/.env

# --- PostgreSQL 18 + pgvector (local container, ADR-1) ---
# Образ: deploy/prod/postgres/Dockerfile (pgvector/pgvector:pg18, ru_RU.UTF-8).
# Проверка после первого старта:
#   docker compose ... exec postgres psql -U avg -d avgexpert \
#     -c "SELECT datcollate FROM pg_database WHERE datname = current_database();"
#   → ru_RU.UTF-8  (PG18: SHOW lc_collate удалён)
# ВАЖНО: PG 18 volume — pg-data:/var/lib/postgresql (не /data). Апгрейд с PG16: pg_dump/restore.
# Смена локали требует нового volume pg-data (или pg_dump/restore).
POSTGRES_USER=avg
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=avgexpert

# --- Public WEB ---
PUBLIC_DOMAIN=your-domain.example.com
PUBLIC_BASE_URL=https://your-domain.example.com
AVGEXPERT_ALLOWED_ORIGINS=https://your-domain.example.com

HTTP_PORT=80
HTTPS_PORT=443

# --- AvgExpert Gateway ---
AVGEXPERT_DEPLOY_ENV=production
KNOWLEDGE_GATEWAY_ENABLED=true
RAG_V2_ENABLED=true
FTS_FALLBACK_ENABLED=true

AVGEXPERT_SECRET=replace-with-at-least-32-random-characters
AVGEXPERT_ADMIN_PASSWORD=change-me-immediately
AVGEXPERT_PORT=8200
AVGEXPERT_PROVIDER_TIMEOUT=120000

VECTOR_STORE=pgvector
VECTOR_EMBEDDING_CONFIG=bge_m3.docker
VECTOR_RERANKER_CONFIG=bge_reranker_v2_m3.docker
EMBEDDING_MOCK=false
RERANK_ENABLED=true
RERANK_MOCK=false

# --- GPU: Tesla L4 vGPU-8-16-L4-8Q (8192 MB VRAM) ---
# Preset: deploy/prod/presets/8gb-vram.env
TEI_CUDA_IMAGE=ghcr.io/huggingface/text-embeddings-inference:89-1.7
TEI_MAX_BATCH_TOKENS=2048

# Llama 7B гибрид: ~2.5 GB TEI + ~4 GB Llama на GPU (остальное CPU/RAM)
LLAMA_CTX_SIZE=4096
LLAMA_THREADS=4
LLAMA_BATCH=256
LLAMA_N_GPU_LAYERS=24

# TEI на CPU, Llama на полный GPU:
#   docker compose -f deploy/prod/compose.yml -f deploy/prod/compose.tei-cpu.override.yml up -d
#   LLAMA_N_GPU_LAYERS=99  LLAMA_CTX_SIZE=8192

# --- Payments (optional) ---
# ROBOKASSA_MERCHANT_LOGIN=
# ROBOKASSA_PASSWORD1=
# ROBOKASSA_PASSWORD2=
# ROBOKASSA_IS_TEST=0
