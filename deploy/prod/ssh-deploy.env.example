# Copy to ssh-deploy.env and fill (do not commit ssh-deploy.env)

# SSH target
SERVER=user@203.0.113.10
SSH_PORT=22

# Path on remote server
REMOTE_ROOT=/opt/avgexpert

# How to deliver code: git | rsync
DEPLOY_MODE=git
GIT_REPO=https://github.com/your-org/cons.git
GIT_BRANCH=main

# For rsync mode: local path to repo root (parent of avgexpert/)
# LOCAL_REPO_ROOT=E:/LA/cons
