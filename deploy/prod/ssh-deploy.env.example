# Copy to ssh-deploy.env and fill (do not commit ssh-deploy.env)

# SSH target
SERVER=ubuntu@203.0.113.10
SSH_PORT=22
# Windows: SSH_IDENTITY=E:/Program/srvib4.pem
# SSH_IDENTITY=

# Path on remote server (repo clone → $REMOTE_ROOT/avgexpert)
REMOTE_ROOT=/opt/avgexpert

# Compose stack: cpu-pilot | gpu-l4 | gpu-l4-8gb  (see deploy/prod/stacks/README.md)
COMPOSE_STACK=cpu-pilot

# How to deliver code: git | rsync
DEPLOY_MODE=git
GIT_REPO=https://github.com/loginovfedor-spec/avgexpert.git
GIT_BRANCH=main

# For rsync mode: local path to repo root (parent of avgexpert/)
# LOCAL_REPO_ROOT=E:/LA/cons
