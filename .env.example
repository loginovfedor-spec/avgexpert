NODE_ENV=development

AVGEXPERT_PORT=8200

AVGEXPERT_SECRET=replace-this-with-at-least-32-random-characters-for-jwt

AVGEXPERT_TOKEN_EXPIRY=7d

AVGEXPERT_ADMIN_PASSWORD=change-me-immediately

AVGEXPERT_ALLOWED_ORIGINS=http://127.0.0.1:8200,http://localhost:8200

AVGEXPERT_PROVIDER_TIMEOUT=60000

AVGEXPERT_TEST_TIMEOUT=5000

ALLOW_CUSTOM_PROVIDER_URLS=false

PUBLIC_BASE_URL=https://example.com

ROBOKASSA_MERCHANT_LOGIN=

ROBOKASSA_PASSWORD1=

ROBOKASSA_PASSWORD2=

ROBOKASSA_TEST_PASSWORD1=

ROBOKASSA_TEST_PASSWORD2=

ROBOKASSA_HASH_ALGO=md5

ROBOKASSA_IS_TEST=1

# RAG v2: false in development; staging/production deploy env → true (see .env.staging.example / .env.production.example)
RAG_V2_ENABLED=false
AVGEXPERT_DEPLOY_ENV=development

# SQLite FTS — degraded fallback only when vector/PG unavailable (S10-2)
FTS_FALLBACK_ENABLED=true

# L1 conversation truncate (S3-7); category input_context_max overrides when set
CONVERSATION_MAX_TOKENS=100000



# Vector KB (RAG v2) — §11.1 self-hosted embedder

# Параметры по умолчанию: src/modules/vector/config/bge_m3.env

VECTOR_EMBEDDING_CONFIG=bge_m3.local

EMBEDDING_PROVIDER=self-hosted

EMBEDDING_MODEL=bge-m3

EMBEDDING_DIMS=1024

EMBEDDING_NAMESPACE=bge-m3-v1

# TEI endpoint (VPC рядом с PG); переопределяет vector/config/bge_m3.env при необходимости

# EMBEDDING_API_URL=http://83.166.253.250:8080/embed

EMBEDDING_API_FORMAT=tei

EMBEDDING_MOCK=false

# Cross-encoder reranker (§11.2 S7b) — expert/sage only
VECTOR_RERANKER_CONFIG=bge_reranker_v2_m3
RERANK_MODEL=bge-reranker-v2-m3
# RERANK_API_URL=http://127.0.0.1:8091/rerank
RERANK_ENABLED=false
RERANK_MOCK=false

# Semantic graph expansion (§11.6 S8) — sage opt-in; category extra_params.semantic_graph_enabled overrides
SEMANTIC_GRAPH_ENABLED=false

VECTOR_STORE=pgvector

# DATABASE_URL — в корневом .env или в providers/config/*.env (см. yandex_file_search.env)

VECTOR_PG_PROVIDER=yandex_file_search



# Ingestion (Спринт 2)

CHUNK_SIZE=800

CHUNK_OVERLAP=150

KB_INGEST_ALLOWED_DIR=webui_src/assets/books

# User KB (S5) — 0 = category defaults (Консультант 3 / Эксперт 5 / Мудрец 10)
KB_USER_MAX_DOCS=0
KB_USER_MAX_FILE_BYTES=5242880

