# Production deployment template (S10-1)
# Copy to production host .env and fill secrets.

NODE_ENV=production
AVGEXPERT_DEPLOY_ENV=production

# RAG v2 on by default when AVGEXPERT_DEPLOY_ENV=production (override explicitly if needed)
# RAG_V2_ENABLED=true

KNOWLEDGE_GATEWAY_ENABLED=true

# SQLite FTS used only as degraded fallback (S10-2); set false to disable entirely
FTS_FALLBACK_ENABLED=true

AVGEXPERT_PORT=8200
AVGEXPERT_SECRET=replace-with-production-secret-at-least-32-chars
AVGEXPERT_ADMIN_PASSWORD=change-me-immediately

VECTOR_EMBEDDING_CONFIG=bge_m3
EMBEDDING_PROVIDER=self-hosted
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024
EMBEDDING_NAMESPACE=bge-m3-v1
EMBEDDING_MOCK=false
EMBEDDING_API_URL=http://83.166.253.250:8080/embed

VECTOR_STORE=pgvector
# DATABASE_URL=postgresql://...
