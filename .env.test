NODE_ENV=test
AVGEXPERT_SECRET=test_secret_that_is_at_least_32_characters_long_for_testing
AVGEXPERT_PORT=8201
AVGEXPERT_TOKEN_EXPIRY=1h
AVGEXPERT_ADMIN_PASSWORD=TestAdminPass123!
AVGEXPERT_ALLOWED_ORIGINS=http://127.0.0.1:8201,http://localhost:8201
AVGEXPERT_PROVIDER_TIMEOUT=5000
AVGEXPERT_TEST_TIMEOUT=5000
ALLOW_CUSTOM_PROVIDER_URLS=false

# PG integration tests (SKIP_PG_INTEGRATION=true чтобы отключить)
DATABASE_URL=postgresql://avg:d0smoke-test-pw@127.0.0.1:5432/avgexpert
APP_PG_ENABLED=true
VECTOR_STORE=pgvector
RAG_V2_ENABLED=true
EMBEDDING_MOCK=true
RERANK_MOCK=true
FTS_FALLBACK_ENABLED=true
FTS_FALLBACK_BACKEND=pg_tsvector
